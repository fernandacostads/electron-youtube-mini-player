{
  "name": "electron-youtube-mini-player",
  "version": "0.0.3",
  "main": "dist/main/main.js",
  "scripts": {
  "compile": "tsc && copyfiles -u 1 \"src/**/*.{html,css}\" dist/",
  "dev": "npm run compile && electron .",
  "start": "electron .",
  "dist": "npm run compile && electron-builder"
},
  "author": "saumya",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-log": "^5.3.3"
  },
  "devDependencies": {
    "@types/electron": "^1.4.38",
    "@types/node": "^25.4.0",
    "copyfiles": "^2.4.1",
    "electron": "^35.7.5",
    "electron-builder": "^24.13.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "build": {
  "appId": "com.fernandacostads.mini-youtube-player",
  "productName": "YT Mini Player",
  "directories": {
    "buildResources": "build"
  },

  "files": [
    "dist/**/*",
    "node_modules/**/*",
    ".env"
  ],

  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },

  "mac": {
    "target": "zip",
    "icon": "build/icon.png"
  },

  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "build/icon.png",
    "category": "AudioVideo"
  }
}
}
